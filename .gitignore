# QuickPoll - .gitignore

# Environment & Secrets
.env
.env.*
!.env.example

# Terraform
terraform.tfvars
terraform.tfvars.json
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log
crash.*.log

# Java / Maven
target/
*.jar
*.war
*.nar
*.class
*.log
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Node.js / Angular
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/
.angular/
.cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
.pytest_cache/
*.egg-info/

# Docker
docker-compose.override.yml

# IDE
.idea/
.vscode/
*.swp
*.swo
*.iml
.project
.classpath
.settings/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Database
*.db
*.sqlite
*.sqlite3

# Logs & Temp
logs/
*.log
tmp/
temp/
.qodo

# Monitoring data
monitoring/prometheus/data/
monitoring/grafana/data/*.secrets-backup.env
.secrets-backup.env
.claude/
frontend/src/app/pages/settings/NAVIGATION_INTEGRATION.md
frontend/src/app/pages/settings/README.md
frontend/src/app/pages/settings/NAVIGATION_INTEGRATION.md
