{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Polls List Response Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["pollId", "title", "type", "status"],
    "properties": {
      "pollId": {
        "type": "integer"
      },
      "title": {
        "type": "string"
      },
      "type": {
        "type": "string",
        "enum": ["SINGLE_SELECT", "MULTI_SELECT"]
      },
      "status": {
        "type": "string",
        "enum": ["OPEN", "CLOSED"]
      },
      "expiresAt": {
        "type": ["string", "null"],
        "format": "date-time"
      },
      "createdBy": {
        "type": "string"
      },
      "participationRate": {
        "type": ["number", "null"],
        "minimum": 0,
        "maximum": 100
      }
    }
  }
}