{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vote Response Schema",
  "type": "object",
  "required": ["voteId", "pollId", "selectedOptions", "createdAt"],
  "properties": {
    "voteId": {
      "type": "integer",
      "description": "Unique vote identifier"
    },
    "pollId": {
      "type": "integer",
      "description": "Poll that was voted on"
    },
    "selectedOptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer"
      },
      "description": "List of selected option IDs"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when vote was cast"
    }
  },
  "additionalProperties": false
}