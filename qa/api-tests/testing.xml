<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="QuickPoll API Test Suite" verbose="2" thread-count="1">

    <!-- ── Environment Parameters ────────────────────────────────────────── -->
    <parameter name="baseUrl"       value="http://localhost:8080/api"/>
    <parameter name="adminEmail"    value="admin@amalitech.com"/>
    <parameter name="userEmail"     value="user@amalitech.com"/>
    <parameter name="validPassword" value="password123"/>

    <!-- ── Auth Tests ─────────────────────────────────────────────────────── -->
    <test name="Authentication Tests">
        <parameter name="testGroup" value="auth"/>
        <classes>
            <class name="com.amalitech.qa.auth.AuthApiTest"/>
        </classes>
    </test>

    <!-- ── Poll Tests ─────────────────────────────────────────────────────── -->
    <test name="Poll Management Tests">
        <parameter name="testGroup" value="poll"/>
        <classes>
            <class name="com.amalitech.qa.poll.PollApiTest"/>
        </classes>
    </test>

    <!-- ── Vote Tests ─────────────────────────────────────────────────────── -->
    <test name="Voting Tests">
        <parameter name="testGroup" value="vote"/>
        <classes>
            <class name="com.amalitech.qa.vote.VoteApiTest"/>
        </classes>
    </test>

    <!-- ── Results Tests ──────────────────────────────────────────────────── -->
    <test name="Results Tests">
        <parameter name="testGroup" value="results"/>
        <classes>
            <class name="com.amalitech.qa.results.ResultsApiTest"/>
        </classes>
    </test>

    <!-- ── Dashboard Tests ────────────────────────────────────────────────── -->
    <test name="Dashboard Tests">
        <parameter name="testGroup" value="dashboard"/>
        <classes>
            <class name="com.amalitech.qa.dashboard.DashboardApiTest"/>
        </classes>
    </test>

</suite>
